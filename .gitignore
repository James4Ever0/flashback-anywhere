# =============================================================================
# flashback-anywhere — root .gitignore
# Ignores large/generated artifacts across all sub-projects while keeping
# source files, scripts, READMEs, plans, and configuration.
# =============================================================================
esp32cam-sdk
openglass-esp32-info 

# ------------------------------------------------------------------------------
# OS and editor files
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------------------------
# Local environment / secrets
# ------------------------------------------------------------------------------
.claude/settings.local.json
.env
.env.local
.env.*.local

# ------------------------------------------------------------------------------
# Logs, dumps, and transient output
# ------------------------------------------------------------------------------
*.log
hardcopy.0
output.txt
test.txt
debug-*.txt

# ------------------------------------------------------------------------------
# Archives, installers, and large vendor packages
# ------------------------------------------------------------------------------
*.zip
*.rar
*.tar.gz
*.tgz
*.tar.bz2
*.bz2
*.7z
*.exe
*.msi
*.deb
*.rpm
*.unitypackage

# ------------------------------------------------------------------------------
# Generated documents and media
# ------------------------------------------------------------------------------
*.docx
*.odt
*.pdf
*.mov
*.avi
*.mp4
*.mkv
*.webm

# ------------------------------------------------------------------------------
# Images (ignored by default; app assets and public resources are re-included)
# ------------------------------------------------------------------------------
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.webp
!**/assets/
!**/assets/**
!**/public/
!**/public/**

# ------------------------------------------------------------------------------
# Compiled / build artifacts
# ------------------------------------------------------------------------------
*.o
*.obj
*.a
*.so
*.dylib
*.dll
*.class

# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ------------------------------------------------------------------------------
# Node / JavaScript / Expo
# ------------------------------------------------------------------------------
node_modules/
build/
dist/
.expo/
